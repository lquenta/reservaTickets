APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Zona horaria (ej: America/La_Paz, Europe/Madrid). Ver https://www.php.net/manual/en/timezones.php
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# En producción con HTTPS usar: SESSION_SECURE_COOKIE=true (evita 419 en login/logout)
# SESSION_SECURE_COOKIE=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
# Opciones: log, smtpkit, sendgrid, mailgun (MAILGUN_API_KEY + MAILGUN_DOMAIN)
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# SmtpKit API (https://smtpkit.com) - usar con MAIL_MAILER=smtpkit
SMTPKIT_API_KEY=
SMTPKIT_API_URL=
# SMTPKIT_VERIFY_SSL=false

# SendGrid API (https://sendgrid.com) - usar con MAIL_MAILER=sendgrid
SENDGRID_API_KEY=
# Si falla cURL 60 (SSL) en Windows/local: SENDGRID_VERIFY_SSL=false (solo desarrollo)
# SENDGRID_VERIFY_SSL=

# Mailgun (https://mailgun.com) - usar con MAIL_MAILER=mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
# Dominio EU: MAILGUN_ENDPOINT=https://api.eu.mailgun.net
# MAILGUN_ENDPOINT=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# reCAPTCHA for register and reservation forms (leave empty to skip in local).
# Get keys at https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Telegram notificaciones (Admin → Notificaciones). Si en local falla con error SSL (cURL 60), usar false
TELEGRAM_VERIFY_SSL=true

# API key para el validador de tickets en puerta (app acomodador). Enviar en header X-API-Key al llamar POST /api/v1/tickets/validate
TICKET_VALIDATOR_API_ENABLED=true
TICKET_VALIDATOR_API_KEY=
# Modo test para validar el APK sin tickets reales:
# - TICKET_VALIDATOR_TEST_MODE=true activa modo test
# - TICKET_VALIDATOR_TEST_FORCE_VALID=true responde siempre válido
# - TICKET_VALIDATOR_TEST_FORCE_VALID=false responde siempre inválido
# - TICKET_VALIDATOR_TEST_FORCE_VALID=warning responde "YA PASO" (advertencia, ticket ya usado)
TICKET_VALIDATOR_TEST_MODE=false
TICKET_VALIDATOR_TEST_FORCE_VALID=
